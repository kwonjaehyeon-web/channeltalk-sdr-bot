# Streamlit Cloud 배포 시 이 파일을 참고해 App Settings > Secrets에 입력
# (이 파일은 커밋해도 안전 — 실제 값 없음)

OPENAI_API_KEY = "sk-..."
SERPER_API_KEY = "..."
NOTION_TOKEN = "ntn_..."
NOTION_DATABASE_ID = "..."            # 분석 결과 저장 DB
NOTION_CONTEXT_PAGE_ID = "..."       # 채널톡 제품 컨텍스트 페이지 ID
NOTION_GUIDELINES_PAGE_ID = "..."    # SDR 분석 가이드라인 페이지 ID (선택)
