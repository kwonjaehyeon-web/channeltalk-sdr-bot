# ─── Slack ───────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-bot-token        # OAuth Bot Token
SLACK_APP_TOKEN=xapp-your-app-token        # Socket Mode App Token
SLACK_SIGNING_SECRET=your-signing-secret

# ─── LLM ─────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key
GEMINI_API_KEY=your-gemini-key
LLM_PROVIDER=openai                        # openai | gemini (fallback 순서)

# ─── 수집 API ─────────────────────────────────────────
DART_API_KEY=your-dart-api-key             # https://opendart.fss.or.kr 에서 발급
SERPER_API_KEY=your-serper-key             # https://serper.dev 에서 발급

# ─── DB ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/sales_intel

# ─── Redis (Celery 브로커) ────────────────────────────
REDIS_URL=redis://localhost:6379/0
